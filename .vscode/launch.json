{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Run Extension",
            "type": "extensionHost",
            "request": "launch",
            "runtimeExecutable": "${execPath}",
            "args": [
                "--extensionDevelopmentPath=${getWorkspaceFolder:mcp-monitor}"
            ],
            "outFiles": [
                "${getWorkspaceFolder:mcp-monitor}/out/**/*.js"
            ],
            "preLaunchTask": "${defaultBuildTask}"
        },
        {
            "name": "Extension Tests",
            "type": "extensionHost",
            "request": "launch",
            "runtimeExecutable": "${execPath}",
            "args": [
                "--extensionDevelopmentPath=${getWorkspaceFolder:mcp-monitor}",
                "--extensionTestsPath=${getWorkspaceFolder:mcp-monitor}/out/test/index"
            ],
            "outFiles": [
                "${getWorkspaceFolder:mcp-monitor}/out/**/*.js"
            ],
            "preLaunchTask": "${defaultBuildTask}"
        }
    ]
}