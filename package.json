{
  "name": "mcp-monitor",
  "displayName": "MCP Monitor",
  "description": "Monitor MCP server status in real-time with a premium dashboard.",
  "version": "2.0.0",
  "publisher": "akkyey",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "mcp-monitor",
          "title": "MCP Monitor",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "mcp-monitor": [
        {
          "type": "webview",
          "id": "mcp-monitor-view",
          "name": "Server Status",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "commands": [
      {
        "command": "mcp-monitor.refresh",
        "title": "Refresh MCP Status",
        "icon": "$(refresh)"
      }
    ],
    "configuration": {
      "title": "MCP Monitor",
      "properties": {
        "mcpMonitor.configPath": {
          "type": "string",
          "default": "",
          "description": "Path to mcp_config.json. If empty, it searches for it in workspace folders and standard locations."
        },
        "mcpMonitor.tier": {
          "type": "string",
          "enum": [
            "free",
            "paid"
          ],
          "default": "free",
          "description": "Select your Gemini API Tier to simulate Quota limits (Free: 15 RPM, Paid: 2000 RPM)."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js",
    "package": "npx -y @vscode/vsce package",
    "install-local": "npm run package && code --install-extension *.vsix"
  },
  "devDependencies": {
    "@types/vscode": "^1.75.0",
    "@types/node": "16.x",
    "typescript": "^4.9.5",
    "eslint": "^8.36.0",
    "@typescript-eslint/parser": "^5.56.0",
    "@typescript-eslint/eslint-plugin": "^5.56.0"
  }
}