{
  "name": "mcp-monitor",
  "displayName": "MCP Monitor",
  "description": "Monitor MCP server status in real-time with a premium dashboard.",
  "version": "2.0.0",
  "publisher": "akkyey",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "mcp-monitor",
          "title": "MCP Monitor",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "mcp-monitor": [
        {
          "type": "webview",
          "id": "mcp-monitor-view",
          "name": "Server Status",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "commands": [
      {
        "command": "mcp-monitor.refresh",
        "title": "Refresh MCP Status",
        "icon": "$(refresh)"
      }
    ],
    "configuration": {
      "title": "MCP Monitor",
      "properties": {
        "mcpMonitor.configPath": {
          "type": "string",
          "default": "",
          "description": "Path to mcp_config.json. If empty, it searches for it in workspace folders and standard locations."
        },
        "mcpMonitor.tier": {
          "type": "string",
          "default": "free",
          "description": "Select your Gemini API Tier to simulate Quota limits (Free: 15 RPM, Paid: 2000 RPM)."
        }
      }
    }
  },
  "scripts": {
    "package": "vsce package",
    "compile": "tsc -p ./"
  },
  "devDependencies": {
    "@types/vscode": "^1.75.0",
    "@vscode/vsce": "latest",
    "typescript": "^4.9.5"
  }
}